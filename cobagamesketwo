<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gen-Z Coin Clicker Game</title>
    <style>
        body {
            background: linear-gradient(135deg, #0f172a, #1e1b4b);
            color: #fff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
        }
        h1 {
            color: #38bdf8;
            text-shadow: 0 0 10px rgba(56, 189, 248, 0.5);
        }
        #coin {
            width: 150px;
            height: 150px;
            background: radial-gradient(circle, #fcd34d, #f59e0b);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
            cursor: pointer;
            box-shadow: 0 0 20px #f59e0b;
            transition: transform 0.1s ease;
            user-select: none;
        }
        #coin:active {
            transform: scale(0.9);
        }
        .score-board {
            font-size: 1.5rem;
            margin-top: 20px;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <h1>Click the Coin, Bro! 🪙</h1>
    <div id="coin">✨</div>
    <div class="score-board">Score: <span id="score">0</span></div>

    <script>
        let score = 0;
        const scoreDisplay = document.getElementById('score');
        const coin = document.getElementById('coin');

        coin.addEventListener('click', () => {
            score++;
            scoreDisplay.textContent = score;
            
            // Efek rasi bintang kecil saat diklik (opsional)
            if(score === 50) {
                alert("Slay! Kamu mencapai 50 poin! 🚀");
            }
        });
    </script>
</body>
</html>
